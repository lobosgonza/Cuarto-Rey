<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>4to Rey</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bulma@0.9.1/css/bulma.min.css">

    <!-- css -->
    <link rel="stylesheet" href="css/styles.css">
</head>

<body>
    <section class="section">

    <div class="columns">
        <div class="column bg-white is-one-third">
<div id="listaJugadores">
    <% numJugadores.forEach((nombre,index)=>{ %>
    <p id=<%= index %>><%= nombre %></p>
    <% }) %>
</div>
</div>



<div class="column bg-white is-one-third">
<button onClick="randomCard()" class="button is-medium" id="recoger">Recoge una carta</button>
<p id="number"></p>
<p id="pinta"></p>
<button class="button" class="button">Volver a Jugar</button>
</div>

<div class="column bg-white is-one-third">
    <h1>Cuarto Rey</h1>
    <h2 id="turnDisplay">Turno de </h2>
</div>


</div>


</section>

</body>

<script src="https://code.jquery.com/jquery-3.5.1.min.js" integrity="sha256-9/aliU8dGd2tb6OSsuzixeV4y/faTqgFtohetphbbj0=" crossorigin="anonymous"></script>
<script src="/js/index.js"></script>
<script id="qMazos"> <%= cantidadMazos %> </script>
<script id="playerTurn"> <%= numJugadores %> </script>


   


</html>